# LiveKit credentials (get from https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Groq AI API key
GROQ_API_KEY=

# Sarvam AI API key (get from https://dashboard.sarvam.ai)
SARVAM_API_KEY=your_sarvam_api_key

# OpenAI API key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key

# Deepgram API key (get from https://console.deepgram.com)
DEEPGRAM_API_KEY=

# Google Cloud credentials (used when STT_PROVIDER = "google")
# Option 1 – path to a service-account JSON file (download from GCP Console → IAM → Service Accounts)
# Option 2 – leave blank and run: gcloud auth application-default login
# Make sure the "Cloud Speech-to-Text API" is enabled in your GCP project.
GOOGLE_APPLICATION_CREDENTIALS=

# Supabase configuration for ticketing system
SUPABASE_URL=https://your-project-id.supabase.co/rest/v1
SUPABASE_API_KEY=your-supabase-api-key

GOOGLE_API_KEY=you-google-api-key (from https://aistudio.google.com/projects)